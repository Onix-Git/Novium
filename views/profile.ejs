<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Profil NOVIUM</title>
<link rel="stylesheet" href="public/styles.css">
</head>
<body>

<header>
  <a href="index.html">← Dashboard</a>
  <h1>Profil</h1>
</header>

<main>
  <p>Pseudo : <span id="pseudoDisplay"></span></p>
  <p>Email : <span id="emailDisplay"></span></p>

  <h2>Connexions</h2>
  <ul id="connectionsList"></ul>

  <a href="connect.html" class="btn">Ajouter connexion</a>
  <a href="settings.html" class="btn">Paramètres</a>

<script>
let user = JSON.parse(localStorage.getItem("noviumUser")) || {
  pseudo: "Guillaume",
  email: "guillaume@email.com",
  connections: []
};

document.getElementById("pseudoDisplay").innerText = user.pseudo;
document.getElementById("emailDisplay").innerText = user.email;

let list = document.getElementById("connectionsList");
list.innerHTML = user.connections.length === 0 ? "<li>Aucune connexion</li>" :
user.connections.map(c=>`<li>${c.provider} : ${c.email}</li>`).join("");
</script>

</main>
</body>
</html>
