<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Paramètres NOVIUM</title>
<link rel="stylesheet" href="public/styles.css">
</head>
<body>

<header>
  <a href="profile.html">← Profil</a>
  <h1>Paramètres</h1>
</header>

<main>
<form id="settingsForm">
  <input type="text" id="pseudoInput" placeholder="Nouveau pseudo">
  <input type="email" id="emailInput" placeholder="Nouvel email">
  <button type="submit" class="btn">Enregistrer</button>
</form>

<script>
let user = JSON.parse(localStorage.getItem("noviumUser")) || {
  pseudo: "Guillaume",
  email: "guillaume@email.com",
  connections: []
};

document.getElementById("pseudoInput").value = user.pseudo;
document.getElementById("emailInput").value = user.email;

document.getElementById("settingsForm").onsubmit = function(e){
  e.preventDefault();
  user.pseudo = document.getElementById("pseudoInput").value;
  user.email = document.getElementById("emailInput").value;
  localStorage.setItem("noviumUser", JSON.stringify(user));
  alert("Profil mis à jour !");
};
</script>

</main>
</body>
</html>
