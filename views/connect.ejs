<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Ajouter connexion NOVIUM</title>
<link rel="stylesheet" href="public/styles.css">
</head>
<body>

<header>
  <a href="profile.html">← Profil</a>
  <h1>Ajouter connexion</h1>
</header>

<main>
<form id="connectForm">
  <select id="providerSelect">
    <option value="Google">Google</option>
    <option value="Apple">Apple</option>
    <option value="Microsoft">Microsoft</option>
  </select>
  <input type="email" id="providerEmail" placeholder="Email du compte">
  <button type="submit" class="btn">Se connecter</button>
</form>

<script>
let user = JSON.parse(localStorage.getItem("noviumUser")) || {
  pseudo: "Guillaume",
  email: "guillaume@email.com",
  connections: []
};

document.getElementById("connectForm").onsubmit = function(e){
  e.preventDefault();
  let provider = document.getElementById("providerSelect").value;
  let email = document.getElementById("providerEmail").value;
  if(email){
    user.connections.push({provider,email});
    localStorage.setItem("noviumUser", JSON.stringify(user));
    alert(provider + " ajouté !");
    window.location.href = "profile.html";
  }
};
</script>

</main>
</body>
</html>
