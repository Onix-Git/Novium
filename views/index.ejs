<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>NOVIUM Dashboard</title>
<link rel="stylesheet" href="/styles.css">
</head>
<body>

<header>
<h1>NOVIUM</h1>
<a href="/profile" class="avatar">
<%= user.pseudo.charAt(0).toUpperCase() %>
</a>
</header>

<main>

<h2>Dashboard Principal</h2>

<div class="card">
  <p>📅 Événements : <strong><%= summary.events %></strong></p>
  <p>📝 Notes : <strong><%= summary.notes %></strong></p>
  <p>📧 Emails : <strong><%= summary.emails %></strong></p>
  <p>🔗 Connexions : <strong><%= summary.connections %></strong></p>
</div>

</main>

</body>
</html>
